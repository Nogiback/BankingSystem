@model IEnumerable<BankingSystem.Models.Account>
@{
  ViewData["Title"] = "Accounts";
}

<h2>All Accounts</h2>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Account Number</th>
      <th>Type</th>
      <th>Balance</th>
      <th>Customer</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var item in Model)
    {
      <tr>
        <td>@item.AccountNumber</td>
        <td>@item.AccountType</td>
        <td>@item.Balance.ToString("C")</td>
        <td>@(item.Customer != null ? item.Customer.FirstName + " " + item.Customer.LastName : "")</td>
        <td>
          <a asp-action="Details" asp-route-id="@item.AccountId" class="btn btn-primary btn-sm">Details</a>
        </td>
      </tr>
    }
  </tbody>
</table>
