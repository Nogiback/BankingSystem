@model BankingSystem.Models.Transaction
@{
  ViewData["Title"] = "Deposit";
  decimal balance = ViewBag.Balance ?? 0m;
}

<h2>Make a Deposit</h2>
<div class="alert alert-info">
  <strong>Current Balance:</strong> @balance.ToString("C")
</div>

<div class="row">
  <div class="col-md-4">
    <form asp-action="Deposit" method="post">
      <input type="hidden" asp-for="AccountId" />

      <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
      </div>

      <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
      </div>

      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

      <button type="submit" class="btn btn-success">Confirm Deposit</button>
      <a asp-controller="Account" asp-action="Details" asp-route-id="@Model.AccountId"
         class="btn btn-outline-secondary">Cancel</a>
    </form>
  </div>
</div>
