@model BankingSystem.Models.Account
@{
  ViewData["Title"] = "Account Details";
}

<h2>Account Details</h2>

<div class="card mb-4">
  <div class="card-body">
    <h5 class="card-title">@Model.AccountNumber - @Model.AccountType</h5>
    <h6 class="card-subtitle mb-2 text-muted">Customer: @Model.Customer?.FirstName @Model.Customer?.LastName</h6>
    <p class="card-text">
      <strong>Current Balance:</strong> <span class="badge bg-success"
                                              style="font-size: 1.1em;">@Model.Balance.ToString("C")</span>
    </p>
        
    <div class="mt-3">
      <a asp-controller="Transaction" asp-action="Deposit" asp-route-accountId="@Model.AccountId"
         class="btn btn-primary">Deposit</a>
      <a asp-controller="Transaction" asp-action="Withdraw" asp-route-accountId="@Model.AccountId"
         class="btn btn-warning">Withdraw</a>
      <a asp-controller="Transaction" asp-action="History" asp-route-accountId="@Model.AccountId"
         class="btn btn-secondary">Transaction History</a>
    </div>
  </div>
</div>

<a asp-action="Index" class="btn btn-outline-secondary">Back to Accounts</a>